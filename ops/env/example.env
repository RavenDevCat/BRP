# Copy this file to a server-local env file, then edit values for that server.
# Do not commit real API keys or personal machine paths.

# Python executables
BACKEND_PYTHON=python3
CLIENT_PYTHON=python3

# API keys
AMAP_API_KEY=
KAKAO_REST_API_KEY=
GOOGLE_GEOCODE_API_KEY=

# Backend service
BRP_BACKEND_HOST=127.0.0.1
BRP_BACKEND_PORT=8001

# Client service
BRP_BACKEND_BASE_URL=http://127.0.0.1:8001
BRP_BACKEND_TIMEOUT_SECONDS=1800
STREAMLIT_SERVER_ADDRESS=127.0.0.1
STREAMLIT_SERVER_PORT=8501

# OSRM data and bind settings
OSRM_LOCAL_DATA_DIR=/opt/brp/osrm-data
OSRM_BIND_HOST=127.0.0.1

# OSRM endpoint mapping
OSRM_BASE_URL_CHINA_SHANGHAI=http://127.0.0.1:5002
OSRM_BASE_URL_CHINA_BEIJING=http://127.0.0.1:5003
OSRM_BASE_URL_CHINA_SUZHOU=http://127.0.0.1:5004
OSRM_BASE_URL_CHINA_XIAN=http://127.0.0.1:5005
OSRM_BASE_URL_SOUTH_KOREA=http://127.0.0.1:5006
OSRM_BASE_URL_SOUTH_KOREA_SEOUL=http://127.0.0.1:5006
