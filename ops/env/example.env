# Copy this file to a server-local env file, then edit values for that server.
# Do not commit real API keys or environment-specific paths.

# Python executables
BACKEND_PYTHON=python3
CLIENT_PYTHON=python3

# API keys
AMAP_API_KEY=
KAKAO_REST_API_KEY=
GOOGLE_GEOCODE_API_KEY=
GOOGLE_GEOCODE_BASE_URL=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_GEOCODE_TIMEOUT_SECONDS=8
# Bangkok geocoding can temporarily use a narrow Google relay. Leave mode blank
# unless deliberately enabled.
BRP_BK_GEOCODE_MODE=
BRP_GOOGLE_GEOCODE_RELAY_URL=
BRP_GOOGLE_GEOCODE_RELAY_FALLBACK_URL=
BRP_GOOGLE_GEOCODE_RELAY_TOKEN=
BRP_GOOGLE_GEOCODE_RELAY_TIMEOUT_SECONDS=8
# Relay server settings, used on the relay host.
BRP_GOOGLE_GEOCODE_RELAY_HOST=127.0.0.1
BRP_GOOGLE_GEOCODE_RELAY_PORT=8811
BRP_GOOGLE_GEOCODE_RELAY_USAGE_PATH=
BRP_GOOGLE_GEOCODE_RELAY_DAILY_LIMIT=1000
BRP_GOOGLE_GEOCODE_RELAY_MONTHLY_LIMIT=10000
BRP_GOOGLE_GEOCODE_RELAY_MAX_QPS=2.8
BRP_GOOGLE_GEOCODE_RELAY_TIMEZONE=Asia/Seoul
BRP_GOOGLE_GEOCODE_RELAY_ALLOW_NON_BK=false
BRP_GOOGLE_GEOCODE_RELAY_UPSTREAM_TIMEOUT_SECONDS=8
# Optional only for non-KR experimental route-provider checks. KR profile
# refresh uses Kakao Navi because Google Routes returned empty Seoul routes.
GOOGLE_ROUTES_API_KEY=
BRP_SHOW_GOOGLE_GEOCODE_USAGE=false
BRP_ROUTE_COST_MARKET=
BRP_ROUTE_COST_CHINA_HOSTS=
BRP_ROUTE_COST_KOREA_HOSTS=
BRP_BYPASS_ENV_PROXY_HOSTS=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
BRP_AI_AUDIT_LANGUAGE=English
BRP_AI_AUDIT_TIMEOUT_SECONDS=90
BRP_AI_AUDIT_MAX_TOKENS=8192
BRP_DEEPSEEK_MAX_QPS=1.0
BRP_RUNTIME_DB_PATH=
BRP_QUOTA_DB_PATH=
BRP_OSRM_MANAGER_DB_PATH=

# Backend service
BRP_BACKEND_HOST=127.0.0.1
BRP_BACKEND_PORT=8001
# Set to 1 on memory-constrained shared hosts. Use BRP_JOB_CONCURRENCY_DIR to
# share the limit across staging/prod backends on the same host.
BRP_MAX_CONCURRENT_JOBS=0
BRP_JOB_CONCURRENCY_DIR=
BRP_JOB_QUEUE_POLL_SECONDS=5
BRP_JOB_SLOT_ATTACH_STALE_SECONDS=300
# Use an absolute server-local path in production, for example:
# BRP_BACKEND_JOBS_DIR=/srv/brp/runtime/jobs
BRP_BACKEND_JOBS_DIR=
# Use an absolute server-local path in production, for example:
# BRP_SIDE_TOOLS_DIR=/srv/brp/runtime/side_tools
BRP_SIDE_TOOLS_DIR=
# Use absolute server-local paths when staging/prod should share provider caches
# and side-tool cache-backed histories.
BRP_CLIENT_CACHE_DIR=
BRP_BACKEND_CACHE_DIR=

# Live traffic sampling for workday AM/PM peak buffers.
# These use the basic AMap driving-route API against saved current-plan jobs.
BRP_LIVE_TRAFFIC_PROVIDER=auto
BRP_LIVE_TRAFFIC_TO_SCHOOL_JOB_ID=
BRP_LIVE_TRAFFIC_TO_SCHOOL_SOURCE=route_audit_job
BRP_LIVE_TRAFFIC_TO_SCHOOL_RUN_ID=
BRP_LIVE_TRAFFIC_TO_SCHOOL_MARKET=CN
BRP_LIVE_TRAFFIC_TO_SCHOOL_CITY=Shanghai
BRP_LIVE_TRAFFIC_FROM_SCHOOL_JOB_ID=
BRP_LIVE_TRAFFIC_FROM_SCHOOL_SOURCE=route_audit_job
BRP_LIVE_TRAFFIC_FROM_SCHOOL_RUN_ID=
BRP_LIVE_TRAFFIC_FROM_SCHOOL_MARKET=CN
BRP_LIVE_TRAFFIC_FROM_SCHOOL_CITY=Shanghai
# Leave blank to use the platform default runtime path. On Windows/KR that is
# the repository-local state directory; on Linux it remains /opt/brp/shared/runtime.
BRP_LIVE_TRAFFIC_SAMPLE_DIR=
BRP_LIVE_TRAFFIC_BASELINE_DIR=
BRP_LIVE_TRAFFIC_AM_TARGET_ARRIVAL_LOCAL_TIME=08:00
BRP_LIVE_TRAFFIC_AM_ROUTE_START_TIMES_PATH=
BRP_LIVE_TRAFFIC_PM_DEPARTURE_LOCAL_TIME=15:40
BRP_LIVE_TRAFFIC_TIMEZONE=Asia/Shanghai
BRP_LIVE_TRAFFIC_AM_ON_CALENDAR="Mon..Fri 06:20:00 Asia/Shanghai"
BRP_LIVE_TRAFFIC_PM_ON_CALENDAR="Mon..Fri 15:40:00 Asia/Shanghai"
BRP_LIVE_TRAFFIC_AM_WINDOW_START=06:20
BRP_LIVE_TRAFFIC_AM_WINDOW_END=07:30
BRP_LIVE_TRAFFIC_AM_WINDOW_INTERVAL_SECONDS=300
BRP_LIVE_TRAFFIC_DEPARTURE_MULTIPLIER=1.84
BRP_LIVE_TRAFFIC_ROUTE_DUE_WINDOW_MINUTES=5
BRP_LIVE_TRAFFIC_REQUEST_SLEEP_SECONDS=0.45
BRP_LIVE_TRAFFIC_AMAP_STRATEGY=4
# Optional non-KR Google Routes provider controls. Do not use these for KR.
BRP_GOOGLE_ROUTES_USAGE_PATH=
BRP_GOOGLE_ROUTES_MONTHLY_SAFETY_CAP=4000
BRP_GOOGLE_ROUTES_DAILY_CAP=250
BRP_GOOGLE_ROUTES_MAX_CALLS_PER_REFRESH=250
BRP_GOOGLE_ROUTES_MAX_INTERMEDIATES=25
BRP_GOOGLE_ROUTES_ROUTING_PREFERENCE=TRAFFIC_AWARE
BRP_KAKAO_NAVI_USAGE_PATH=
BRP_KAKAO_NAVI_MONTHLY_SAFETY_CAP=4000
BRP_KAKAO_NAVI_DAILY_CAP=500
BRP_KAKAO_NAVI_MAX_CALLS_PER_REFRESH=500
BRP_KAKAO_NAVI_MAX_WAYPOINTS=5
BRP_KAKAO_NAVI_INTER_SEGMENT_DWELL_SECONDS=0

# South Korea final route timing uses Kakao Navi future directions per job.
# Do not install a KR weekly coefficient sampler/timer for normal production.
# BRP_KAKAO_NAVI_FUTURE_DIRECTIONS_URL=https://apis-navi.kakaomobility.com/v1/future/directions
BRP_KAKAO_NAVI_TIMEOUT_SECONDS=20
BRP_KAKAO_NAVI_MAX_QPS=2.8

# Client service
BRP_BACKEND_BASE_URL=http://127.0.0.1:8001
BRP_BACKEND_TIMEOUT_SECONDS=1800
BRP_BACKEND_SERVICE_TOKEN=
# Authentication provider. Keep production/KR on cloudflare_header unless the
# environment is intentionally migrated to company SSO.
BRP_AUTH_PROVIDER=cloudflare_header
BRP_ENABLE_SCHEDULED_JOBS=true
BRP_AUTH_DISPLAY_NAME="Cloudflare Access"
# Optional overrides for the React shell auth buttons.
BRP_AUTH_LOGIN_URL=
BRP_AUTH_LOGOUT_URL=
BRP_DEV_USER_EMAIL=local@brp.dev
BRP_ADMIN_EMAILS=admin@example.com
# Enable on public React static/proxy hosts that must only be reached through
# Cloudflare Access. Requests without Cf-Access-Authenticated-User-Email return
# 401 at the static/proxy layer.
BRP_REQUIRE_CLOUDFLARE_ACCESS=false


# OSRM data and bind settings
OSRM_LOCAL_DATA_DIR=/srv/brp/osrm-data
OSRM_BIND_HOST=127.0.0.1
OSRM_ENABLED_REGIONS=auto
OSRM_USE_BUILTIN_DEFAULTS=true

# OSRM endpoint mapping
# For production/staging servers, keep only the endpoints this server can actually serve.
# Set OSRM_USE_BUILTIN_DEFAULTS=false to avoid falling back to local dev defaults.
OSRM_BASE_URL_CHINA_SHANGHAI=http://127.0.0.1:5002
OSRM_BASE_URL_CHINA_BEIJING=http://127.0.0.1:5003
OSRM_BASE_URL_CHINA_SUZHOU=http://127.0.0.1:5004
OSRM_BASE_URL_CHINA_XIAN=http://127.0.0.1:5005
OSRM_BASE_URL_SOUTH_KOREA=http://127.0.0.1:5006
OSRM_BASE_URL_SOUTH_KOREA_SEOUL=http://127.0.0.1:5006
OSRM_BASE_URL_BANGKOK=http://127.0.0.1:5007
OSRM_BASE_URL_BK=http://127.0.0.1:5007
# Backward-compatible aliases for workbooks/envs that still say Thailand.
OSRM_BASE_URL_THAILAND=http://127.0.0.1:5007
OSRM_BASE_URL_THAILAND_BANGKOK=http://127.0.0.1:5007
