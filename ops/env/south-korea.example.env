# Copy to ops/env/local.env for a South Korea-only lightweight deployment.
# Do not commit real API keys or environment-specific paths.

# Python executables
BACKEND_PYTHON=python3
CLIENT_PYTHON=python3

# API keys required by the client.
# South Korea geocoding uses Kakao. Google can stay blank unless you use Google fallback paths.
AMAP_API_KEY=
KAKAO_REST_API_KEY=
GOOGLE_GEOCODE_API_KEY=
BRP_SHOW_GOOGLE_GEOCODE_USAGE=true
BRP_ROUTE_COST_MARKET=kr
BRP_ROUTE_COST_CHINA_HOSTS=
BRP_ROUTE_COST_KOREA_HOSTS=
BRP_BYPASS_ENV_PROXY_HOSTS=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
BRP_AI_AUDIT_LANGUAGE=English
BRP_AI_AUDIT_TIMEOUT_SECONDS=90
BRP_AI_AUDIT_MAX_TOKENS=8192
BRP_DEEPSEEK_MAX_QPS=1.0
BRP_API_RATE_LIMIT_DIR=

# Backend service
BRP_BACKEND_HOST=127.0.0.1
BRP_BACKEND_PORT=8001
BRP_BACKEND_JOBS_DIR=/srv/brp/runtime/jobs

# Client service
# When the Streamlit client and backend run on the same server, use the local backend URL.
BRP_BACKEND_BASE_URL=http://127.0.0.1:8001
# React public hosts use same-origin /api; expose a separate public backend URL only for a deliberate legacy client integration.
# BRP_PUBLIC_BACKEND_BASE_URL=
BRP_BACKEND_TIMEOUT_SECONDS=1800
BRP_AUTH_MODE=cloudflare
BRP_DEV_USER_EMAIL=local@brp.dev
BRP_ADMIN_EMAILS=admin@example.com
BRP_BACKEND_SERVICE_TOKEN=replace-with-a-shared-random-token
STREAMLIT_SERVER_ADDRESS=127.0.0.1
STREAMLIT_SERVER_PORT=8501

# South Korea OSRM only
OSRM_LOCAL_DATA_DIR=/srv/brp/osrm-data
OSRM_BIND_HOST=127.0.0.1
OSRM_ENABLED_REGIONS=south-korea
OSRM_USE_BUILTIN_DEFAULTS=false
OSRM_SOUTH_KOREA_PORT=5006
OSRM_SOUTH_KOREA_DATASET_DIR=/srv/brp/osrm-data/south-korea
OSRM_SOUTH_KOREA_DATASET_FILE=south-korea-latest.osrm
OSRM_MAX_TABLE_SIZE=1000
OSRM_EXTRACT_THREADS=2

OSRM_BASE_URL=http://127.0.0.1:5006
OSRM_BASE_URL_SOUTH_KOREA=http://127.0.0.1:5006
OSRM_BASE_URL_SOUTH_KOREA_SEOUL=http://127.0.0.1:5006
